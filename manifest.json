{
  "manifest_version": 2,
  "name": "Google Photos Bulk Deleter",
  "version": "1.0",
  "description": "Delete all photos from Google Photos",
  "permissions": [
    "activeTab",
    "https://photos.google.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "google-photos-deleter@holc-soptim.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "47": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "47": "icon.png"
  }
}
